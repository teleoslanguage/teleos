` Range and Constants `

const var = MAX > 10
const var = GREETING > "Hello"
console.output(MAX)
console.output(GREETING)

range.call; 1 to 10 ; nums
console.output(nums)

range.call; 0 to 4 ; small
table.len(small) = slen
console.output(slen)

` Loop over a range `
create var = i > 0
repeat i until == 5 num then
 create var = val > i
 console.output(val)
end
