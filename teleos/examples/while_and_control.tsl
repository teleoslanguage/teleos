` While Loops and Control Flow `

create var = count > 0
while count < 5 then
 console.output("Count: " + count)
 count++
end

` break out early `
create var = i > 0
while i < 100 then
 do if i == 3 then
  do break
 end
 i++
end
console.output("Stopped at: " + i)

` decrement `
create var = x > 10
while x > 0 then
 x--
end
console.output("Counted down to: " + x)
